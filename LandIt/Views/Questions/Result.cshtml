@model List<LandIt.Models.GeneratedQuestion>
@{
    ViewData["Title"] = "Generated Questions";
    ViewData["UseBootstrap"] = true;
    ViewData["UseIdentityStyles"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var grouped = Model.GroupBy(q => q.Category).ToList();

    var categoryStyles = new Dictionary<string, (string bg, string color, string icon)>
    {
        { "Behavioral",    ("rgba(79,142,247,0.1)",  "#4f8ef7", "ti-user") },
        { "Technical",     ("rgba(34,197,94,0.1)",   "#16a34a", "ti-code") },
        { "Situational",   ("rgba(251,191,36,0.1)",  "#d97706", "ti-alert-circle") },
        { "Culture Fit",   ("rgba(168,85,247,0.1)",  "#9333ea", "ti-heart") },
        { "Role Specific", ("rgba(239,68,68,0.1)",   "#dc2626", "ti-briefcase") },
    };
}

<div class="container py-5" style="max-width:780px;">

    <!--Header-->
        <div style="margin-bottom:2rem;">
            <a href="@Url.Action("Index", "Questions")"
               style="font-size:0.82rem;color:var(--muted2);display:inline-flex;align-items:center;gap:4px;text-decoration:none;margin-bottom:1rem;">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Generate new questions
            </a>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;">
                <div>
                    <div class="sec-eyebrow">AI Generated</div>
                    <h1 class="sec-title" style="margin-bottom:0.25rem;">Your Interview Questions</h1>
                    <p class="step-desc">@Model.Count questions generated across @grouped.Count categories.</p>
                </div>
                <a href="@Url.Action("History", "Questions")"
                   class="btn-ghost"
                   style="display:inline-flex;align-items:center;gap:6px;padding:0.5rem 1rem;text-decoration:none;white-space:nowrap;">
                    <i class="ti ti-history" aria-hidden="true"></i> View history
                </a>
            </div>
        </div>

        <!-- Category summary badges -->
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:2rem;">
                @foreach (var group in grouped)
                {
                    var st = categoryStyles.ContainsKey(group.Key) ? categoryStyles[group.Key] : ("rgba(107,114,128,0.1)", "#6b7280", "ti-help");
                    string bg = st.Item1;
                    string color = st.Item2;
                    string icon = st.Item3;

                    <span style="display:inline-flex;align-items:center;gap:5px;font-size:0.75rem;font-weight:500;padding:4px 10px;border-radius:100px;background:@bg;color:@color;border:0.5px solid @color;">
                        <i class="ti @icon" aria-hidden="true" style="font-size:0.8rem;"></i>
                        @group.Key (@group.Count())
                    </span>
                }
            </div>

            <!-- Questions grouped by category -->
                @foreach (var group in grouped)
                {
                    var st = categoryStyles.ContainsKey(group.Key) ? categoryStyles[group.Key] : ("rgba(107,114,128,0.1)", "#6b7280", "ti-help");
                    string bg = st.Item1;
                    string color = st.Item2;
                    string icon = st.Item3;

                    <div style="margin-bottom:2rem;">

                        <!-- Category header -->
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;padding-bottom:0.6rem;border-bottom:0.5px solid var(--border);">
                                <div style="width:30px;height:30px;border-radius:8px;background:@bg;color:@color;display:flex;align-items:center;justify-content:center;font-size:0.9rem;">
                                    <i class="ti @icon" aria-hidden="true"></i>
                                </div>
                                <span style="font-family:'Sora',sans-serif;font-size:0.95rem;font-weight:600;color:var(--text);">@group.Key</span>
                                <span style="font-size:0.75rem;color:var(--muted);margin-left:2px;">@group.Count() questions</span>
                            </div>

                            <!-- Question cards -->
                                @{
                                    int questionNum = 1;
                                }
                                @foreach (var question in group)
                                {
                                    <div class="app-card" style="margin-bottom:0.85rem;border-left:3px solid @color;">
                                        <div style="display:flex;align-items:flex-start;gap:12px;">
                                            <span style="font-size:0.75rem;font-weight:600;color:@color;background:@bg;padding:3px 8px;border-radius:100px;flex-shrink:0;margin-top:2px;">
                                                @questionNum
                                            </span>
                                            <div style="flex:1;">
                                                <p style="font-size:0.925rem;font-weight:500;color:var(--text);margin:0 0 0.6rem;line-height:1.55;">
                                                    @question.QuestionText
                                                </p>
                                                @if (!string.IsNullOrWhiteSpace(question.Tip))
                                                {
                                                    <div style="display:flex;align-items:flex-start;gap:8px;padding:0.6rem 0.85rem;background:var(--surface2);border-radius:8px;">
                                                        <i class="ti ti-bulb" aria-hidden="true" style="color:var(--blue);font-size:0.9rem;flex-shrink:0;margin-top:2px;"></i>
                                                        <p style="font-size:0.82rem;color:var(--muted2);margin:0;line-height:1.6;">
                                                            <strong style="color:var(--text);">Tip:</strong> @question.Tip
                                                        </p>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    questionNum++;
                                }
                            </div>
                        }

                        <!-- Bottom actions -->
                            <div style="display:flex;gap:0.85rem;flex-wrap:wrap;padding-top:1rem;border-top:0.5px solid var(--border);">
                                <a href="@Url.Action("Index", "Questions")"
                                   class="btn-primary"
                                   style="display:inline-flex;align-items:center;gap:6px;padding:0.65rem 1.5rem;text-decoration:none;">
                                    <i class="ti ti-refresh" aria-hidden="true"></i> Generate new questions
                                </a>
                                <a href="@Url.Action("History", "Questions")"
                                   class="btn-ghost"
                                   style="display:inline-flex;align-items:center;gap:6px;padding:0.65rem 1.5rem;text-decoration:none;">
                                    <i class="ti ti-history" aria-hidden="true"></i> View all past questions
                                </a>
                                <a href="/Account/Dashboard"
                                   class="btn-ghost"
                                   style="display:inline-flex;align-items:center;gap:6px;padding:0.65rem 1.5rem;text-decoration:none;">
                                    <i class="ti ti-layout-dashboard" aria-hidden="true"></i> Dashboard
                                </a>
                            </div>

                        </div>