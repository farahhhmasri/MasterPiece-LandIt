@model LandIt.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["UseBootstrap"] = true;
    ViewData["UseIdentityStyles"] = true;
}

<div class="app-container">

    <!-- header items - cta buttons -->
    <div class="feat-grid" style="margin-bottom: 2rem;">

        <a class="feat-card" asp-controller="Account" asp-action="MyResumes" style="text-decoration:none;">
            <div class="feat-icon">📄</div>
            <div class="feat-title">ATS Resume Analyzer</div>
            <div class="feat-desc">
                Improve and optimize your CV with AI-powered analysis.
            </div>
            <div class="feat-arrow">→</div>
        </a>

        <a class="feat-card" asp-controller="Account" asp-action="MyQuestions" style="text-decoration:none;">
            <div class="feat-icon">🤖</div>
            <div class="feat-title">Interview Questions</div>
            <div class="feat-desc">
                Generate tailored questions based on role and company.
            </div>
            <div class="feat-arrow">→</div>
        </a>

    </div>

    <div class="app-card" style="margin-bottom:2rem; border-left:4px solid var(--blue);">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
            <div>
                <div class="feat-title">My Upcoming Bookings</div>
                <div class="feat-desc">Your next recruiter meetings</div>
            </div>

            <a class="btn-primary"
               asp-controller="Account"
               asp-action="MyBookings">
                View All
            </a>
        </div>

        @if (Model.UpcomingBookings.Any())
        {
            @foreach (var booking in Model.UpcomingBookings)
            {
                <div style="padding:12px 0;border-top:1px solid #eee;">

                    <div class="feat-title">
                        @booking.Recruiter?.FullName
                    </div>

                    <div class="feat-desc">
                        @booking.Recruiter?.Title
                    </div>

                    <div class="feat-desc">
                        📅 @booking.TimeSlot.StartTime.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>

                    <div class="feat-desc">
                        🕒 @booking.TimeSlot.StartTime.ToLocalTime().ToString("hh:mm tt")
                    </div>

                    <div style="margin-top:6px;">
                        <span class="feat-tag">
                            @booking.Status
                        </span>
                    </div>

                </div>
            }
        }
        else
        {
            <div style="padding:1rem 0;color:var(--muted);">
                No upcoming bookings.
            </div>
        }

    </div>


    <!-- search section -->
    <div class="app-card" style="margin-bottom: 2rem;">

        <form method="get" asp-action="Dashboard">

            <div style="display: grid; grid-template-columns: 2fr 1fr auto; gap: 0.75rem;">

                <input class="app-input"
                       type="text"
                       name="search"
                       value="@Model.Search"
                       placeholder="Search recruiters by name, company, skills..." />

                <select class="app-input"
                        name="region"
                        asp-items="Html.GetEnumSelectList<Region>()">
                    <option value="">All Regions</option>
                </select>

                <button class="btn-primary" type="submit">
                    Search
                </button>

            </div>

        </form>

    </div>


    <!-- recruiters result -->
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;">



        @foreach (var recruiter in Model.Recruiters)
        {
            <div class="feat-card">

                <div style="width:48px;height:48px;border-radius:50%;background:var(--blue-dim);color:var(--blue);font-size:1.25rem;font-weight:600;display:flex;align-items:center;justify-content:center;margin-bottom:0.75rem;">
                    @recruiter.FullName.Substring(0, 1).ToUpper()
                </div>

                <div class="feat-title">
                    @recruiter.FullName
                </div>

                <div style="margin-bottom: 0.75rem; display:flex; align-items:center; gap:6px;">
                    @{
                        var avg = recruiter.Reviews != null && recruiter.Reviews.Any()
                            ? recruiter.Reviews.Average(r => r.Rating)
                            : 0;
                        var count = recruiter.Reviews?.Count ?? 0;
                    }
                    @if (count > 0)
                    {
                        <span style="color:#f5a623; font-weight:600; font-size:0.85rem;">
                            ★ @avg.ToString("0.0")
                        </span>
                        <span style="color:var(--muted); font-size:0.8rem;">
                            (@count review@(count == 1 ? "" : "s"))
                        </span>
                    }
                    else
                    {
                        <span style="color:var(--muted); font-size:0.8rem;">No reviews yet</span>
                    }
                </div>

                <div class="feat-desc" style="margin-bottom: 0.75rem;">
                    @recruiter.Title · @recruiter.Company
                </div>

                <div style="margin-bottom: 0.75rem;">
                    <span class="feat-tag">
                        💰 $@recruiter.HourlyRate/hour
                    </span>
                    <span class="feat-tag">
                        📍 @recruiter.Region
                    </span>
                </div>

                <div style="margin-bottom: 1rem;">
                    @foreach (var skill in recruiter.Skills?.Split(',') ?? new string[0])
                    {
                        <span class="feat-tag" style="margin-right: 0.25rem;">
                            @skill.Trim()
                        </span>
                    }
                </div>

                <a asp-controller="Bookings"
                   asp-action="Create"
                   asp-route-recruiterId="@recruiter.Id"
                   class="btn-primary"
                   style="width: 100%; display: inline-block; text-align: center;">
                    Book Meeting
                </a>

            </div>
        }

    </div>

</div>

