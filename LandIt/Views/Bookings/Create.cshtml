@model LandIt.Models.ViewModels.BookingViewModel

@{
    ViewData["Title"] = "Book Session";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width:1100px;margin:0 auto;padding:2rem 1.5rem;">
    <a href="/Account/DashboardRouter">← Back To Dashboard</a>
    <br />
    <br />
    
    <div class="app-card" style="margin-bottom:2rem;">

        <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;">

            <div>
                <div class="sec-title" style="font-size:1.4rem;margin-bottom:0.4rem;">
                    Book a Session
                </div>

                <div class="step-desc">
                    Schedule a meeting with your recruiter
                </div>
            </div>


        </div>

    </div>

    <div class="booking-grid" style="align-items:start;">

        <!-- LEFT SIDE -->
        <div class="app-card">

            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">

                <div class="feat-icon"
                     style="width:56px;height:56px;font-size:1.3rem;">
                    @((Model?.RecruiterName ?? "?").Substring(0, 1))
                </div>

                <div>
                    <div class="feat-title" style="font-size:1.15rem;">
                        @Model.RecruiterName
                    </div>

                    <div class="feat-desc">
                        @Model.RecruiterTitle · @Model.Company
                    </div>
                </div>

            </div>


            <!-- INFO TAGS -->
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;">

                <span class="feat-tag">
                    💰 $@Model.HourlyRate/hour
                </span>

            </div>


            <!-- SESSION NOTES -->
            <div class="feat-card-wide">

                <div class="feat-title" style="font-size:1rem;margin-bottom:0.6rem;">
                    Session Tips
                </div>

                <div class="feat-desc">
                    Add notes about the role you’re targeting, interview stage,
                    or topics you want help with so the recruiter can prepare.
                </div>

            </div>

        </div>


        <!-- RIGHT SIDE -->
        <div class="app-card">

            <form asp-action="Create" method="post">

                <input type="hidden" asp-for="RecruiterId" />

                <!-- VALIDATION -->
                <div asp-validation-summary="All"
                     style="color:#ef4444;margin-bottom:1rem;">
                </div>


                <!-- TIME SLOT -->
                <div style="margin-bottom:1.25rem;">

                    <label asp-for="SelectedTimeSlotId"
                           class="app-label">
                        Select Time Slot
                    </label>

                    <select asp-for="SelectedTimeSlotId"
                            asp-items="Model.AvailableSlots"
                            class="app-input">

                        <option value="">
                            Choose a session time
                        </option>

                    </select>

                    <span asp-validation-for="SelectedTimeSlotId"
                          style="color:#ef4444;font-size:0.82rem;">
                    </span>

                </div>


                <!-- JOB TITLE -->
                <div style="margin-bottom:1.25rem;">

                    <label class="app-label">
                        Job Title
                    </label>

                    <input asp-for="JobTitle"
                           class="app-input"
                           placeholder="e.g. Backend Developer" />

                </div>


                <!-- COMPANY TARGET -->
                <div style="margin-bottom:1.25rem;">

                    <label class="app-label">
                        Target Company
                    </label>

                    <input asp-for="CompanyTarget"
                           class="app-input"
                           placeholder="e.g. Google, Amazon..." />

                </div>


                <!-- NOTES -->
                <div style="margin-bottom:1.5rem;">

                    <label asp-for="Notes"
                           class="app-label">
                        Notes for Recruiter
                    </label>

                    <textarea asp-for="Notes"
                              class="app-input"
                              rows="6"
                              placeholder="Describe what you need help with..."></textarea>

                </div>


                <!-- SUBMIT -->
                <button type="submit"
                        class="btn-primary"
                        style="width:100%; justify-content:center;">

                    Confirm Booking

                </button>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}