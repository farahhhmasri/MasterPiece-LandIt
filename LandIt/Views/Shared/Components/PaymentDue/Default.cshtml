@model IEnumerable<LandIt.Models.Booking>

@if (Model != null && Model.Any())
{
    var count = Model.Count();
    var total = Model.Sum(b => b.Recruiter?.HourlyRate ?? 0m);

    <div id="paymentDueBanner" style="position:sticky;top:0;z-index:99;background:linear-gradient(90deg, rgba(79,142,247,0.15), rgba(79,142,247,0.05));border-bottom:1px solid rgba(79,142,247,0.25);padding:14px 22px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <div style="width:38px;height:38px;border-radius:10px;background:var(--blue);color:#fff;display:grid;place-items:center;flex-shrink:0;">
            <i class="ti ti-credit-card" style="font-size:20px;"></i>
        </div>
        <div style="flex:1;min-width:240px;">
            <div style="font-family:'Sora',sans-serif;font-weight:600;font-size:15px;color:var(--text);letter-spacing:-0.01em;">
                Payment required
            </div>
            <div style="font-size:13px;color:var(--muted2);margin-top:2px;">
                You have <strong>@count</strong> confirmed booking@(count == 1 ? "" : "s") awaiting payment — total <strong>$@total.ToString("0.00")</strong>.
            </div>
        </div>
        <div style="display:flex;gap:8px;">
            <button type="button" onclick="document.getElementById('paymentDueModal').style.display='flex'"
                    style="background:var(--blue);color:#fff;border:0;border-radius:10px;padding:9px 16px;font-weight:600;font-size:14px;cursor:pointer;">
                Pay now
            </button>
            <button type="button" onclick="this.closest('#paymentDueBanner').style.display='none'"
                    style="background:transparent;border:0;color:var(--muted2);cursor:pointer;padding:6px;border-radius:8px;" title="Dismiss">
                <i class="ti ti-x" style="font-size:18px;"></i>
            </button>
        </div>
    </div>

    <!-- Modal -->
    <div id="paymentDueModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(13,15,18,0.55);backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:20px;"
         onclick="if(event.target===this) this.style.display='none'">
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:18px;box-shadow:0 24px 64px rgba(0,0,0,0.25);max-width:560px;width:100%;max-height:85vh;overflow:auto;">
            <div style="padding:22px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
                <div>
                    <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:20px;letter-spacing:-0.02em;color:var(--text);">
                        Bookings awaiting payment
                    </div>
                    <div style="font-size:13px;color:var(--muted);margin-top:3px;">
                        Pay to lock in your confirmed sessions.
                    </div>
                </div>
                <button type="button" onclick="document.getElementById('paymentDueModal').style.display='none'"
                        style="background:transparent;border:0;color:var(--muted);cursor:pointer;width:34px;height:34px;border-radius:8px;display:grid;place-items:center;" title="Close">
                    <i class="ti ti-x" style="font-size:20px;"></i>
                </button>
            </div>

            <div style="padding:18px 24px;">
                @foreach (var b in Model)
                {
                    <div style="display:flex;align-items:center;gap:14px;padding:14px;border:1px solid var(--border);border-radius:14px;margin-bottom:10px;background:var(--surface2);">
                        <div style="width:44px;height:44px;border-radius:10px;background:var(--blue-dim);color:var(--blue);display:grid;place-items:center;flex-shrink:0;">
                            <i class="ti ti-calendar" style="font-size:22px;"></i>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:600;font-size:14.5px;color:var(--text);">
                                @b.Recruiter?.FullName
                            </div>
                            <div style="font-size:12.5px;color:var(--muted);">
                                @(b.TimeSlot != null ? b.TimeSlot.StartTime.ToString("ddd, MMM d · h:mm tt") : "—")
                            </div>
                        </div>
                        <div style="text-align:right;">
                            <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:18px;color:var(--text);letter-spacing:-0.01em;">
                                $@(b.Recruiter?.HourlyRate.ToString("0.00"))
                            </div>
                            <form asp-controller="Bookings" asp-action="Pay" asp-route-id="@b.Id" method="post" style="margin-top:6px;display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:var(--blue);color:#fff;border:0;border-radius:8px;padding:6px 14px;font-weight:600;font-size:12.5px;cursor:pointer;">
                                    Pay
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <div style="padding:14px 24px 20px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
                <div style="font-size:13px;color:var(--muted);">
                    Total: <strong style="color:var(--text);">$@total.ToString("0.00")</strong>
                </div>
                <a asp-controller="Account" asp-action="MyBookings" style="color:var(--blue);font-weight:600;font-size:13.5px;text-decoration:none;">
                    Go to my bookings →
                </a>
            </div>
        </div>
    </div>
}
