@inject Microsoft.AspNetCore.Identity.UserManager<LandIt.Models.AppUser> UserManager


<!DOCTYPE html>
<html lang="en" data-theme="light">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="LandIt — Live mock interviews, ATS resume scoring, and AI question prep. Everything to land your next job." />

        <title>@ViewData["Title"] — LandIt</title>

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
        <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">

        <link rel="stylesheet" href="~/css/landit.css" asp-append-version="true" />

        

        @if (ViewData["UseBootstrap"] is true)
        {
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

        }

        @if (ViewData["UseIdentityStyles"] is true)
        {
            <link rel="stylesheet" href="~/css/identity.css" asp-append-version="true" />
        }
        @await RenderSectionAsync("Head", required: false)

        <script src="~/js/theme.js" asp-append-version="true"></script>
    </head>

    <body>

        <canvas id="networkCanvas"></canvas>

        @{
            var toastSuccess = TempData["ToastMessageSuccess"] as string;
            var toastError = TempData["ToastMessageError"] as string;
            var toastMsg = !string.IsNullOrEmpty(toastError) ? toastError : toastSuccess;
            var toastKind = !string.IsNullOrEmpty(toastError) ? "error" : "success";
        }
        @if (!string.IsNullOrEmpty(toastMsg))
        {
            <div id="landitToast" class="landit-toast @toastKind" role="status" aria-live="polite">
                <i class="ti @(toastKind == "error" ? "ti-alert-circle" : "ti-circle-check") landit-toast-icon"></i>
                <span class="landit-toast-msg">@toastMsg</span>
                <button type="button" class="landit-toast-close" aria-label="Close"
                        onclick="document.getElementById('landitToast').classList.add('hide')">
                    <i class="ti ti-x"></i>
                </button>
            </div>
        }
       




        <nav class="landit-nav">
            <a href="/" class="landit-logo" style="text-decoration:none;">Land<span>It</span></a>

            <div class="nav-right">
                    <!--Hide nav links on internal app pages-->
                    @if (ViewData["HideNavLinks"] is not true)
                    {
                        <div class="nav-links">
                            <a href="/#features" style="text-decoration:none;">Features</a>
                            <a href="/Account/Recruiters" style="text-decoration:none;">Recruiters</a>
                            <a href="/Home/Pricing" style="text-decoration:none;">Pricing</a>
                        </div>
                    }

                    <!-- Dark/Light Mode-->
                        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" type="button">
                            <i class="ti ti-moon" id="themeIcon" aria-hidden="true"></i>
                        </button>

                    <!--Show Menu and Profile if the User is Logged in-->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var currentUser = await UserManager.GetUserAsync(User);

                        <div class="nav-profile" id="navProfile">
                            <button type="button" class="nav-avatar" id="navAvatarBtn" aria-haspopup="true" aria-expanded="false">
                                @if (!string.IsNullOrEmpty(currentUser?.Photo))
                                {
                                    <img src="@currentUser.Photo" alt="Profile" />
                                }
                                else
                                {
                                    <span>@currentUser?.FullName?.Substring(0, 1).ToUpper()</span>
                                }
                            </button>

                            <div class="nav-dropdown" id="navDropdown" role="menu">
                                <div class="nav-dropdown-head">
                                    <div class="name">@currentUser?.FullName</div>
                                    <div class="email">@currentUser?.Email</div>
                                </div>
                                <a href="/Account/ProfileRouter" class="nav-dropdown-item" role="menuitem">
                                    <i class="ti ti-user"></i> Profile
                                </a>
                                <div class="nav-dropdown-sep"></div>
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" asp-route-returnUrl="/">
                                    <button type="submit" class="nav-dropdown-item danger" role="menuitem">
                                        <i class="ti ti-logout"></i> Sign out
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                        @* <a href="/Account/Register" class="btn-nav">Get started</a> *@
                        
            </div>
        </nav>

        @await Component.InvokeAsync("PaymentDue")
        @await Component.InvokeAsync("RecruiterPending")

        @* <main>
            @RenderBody()
        </main> *@



    <div class="page-layout @(ViewData["HideAds"] is true ? "page-layout-full" : "")">
        <main>
            @if (ViewData["HideAds"] is not true)
            {
                <div class="mobile-ad-banner">
                    <div class="ad-label">Sponsored</div>
                    <div class="ad-placeholder-banner">Ad</div>
                </div>
            }
            @RenderBody()
        </main>

        @if (ViewData["HideAds"] is not true)
        {
            <aside class="ads-sidebar" aria-label="Sponsored">
                <div class="ad-slot">
                    <div class="ad-label">Sponsored</div>
                    <div class="ad-placeholder">Ad</div>
                </div>
            </aside>
        }
    </div>










        @if (ViewData["HideFooter"] is not true)
        {
            <footer class="landit-footer">
                <span>© @DateTime.Now.Year LandIt</span>
                <div class="footer-links">
                    <a href="/Home/privacy">Privacy</a>
                    <a href="/Home/terms">Terms</a>
                    <a href="/Home/contact">Contact</a>
                </div>
            </footer>
        }

        @if (ViewData["UseBootstrap"] is true)
        {
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        }

        <script>
            (function () {
                var wrap = document.getElementById('navProfile');
                if (!wrap) return;
                var btn = document.getElementById('navAvatarBtn');
                var dd = document.getElementById('navDropdown');
                function close() { wrap.classList.remove('open'); btn.setAttribute('aria-expanded', 'false'); }
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var isOpen = wrap.classList.toggle('open');
                    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });
                document.addEventListener('click', function (e) { if (!wrap.contains(e.target)) close(); });
                document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
            })();
        </script>

        @await RenderSectionAsync("Scripts", required: false)
        <script>
            (function () {
                var el = document.getElementById('landitToast');
                if (!el) return;
                requestAnimationFrame(function () { el.classList.add('show'); });
                var hideTimer = setTimeout(function () { el.classList.add('hide'); }, 4500);
                el.addEventListener('transitionend', function (e) {
                    if (e.propertyName === 'transform' && el.classList.contains('hide')) {
                        el.parentNode && el.parentNode.removeChild(el);
                    }
                });
                el.querySelector('.landit-toast-close')?.addEventListener('click', function () {
                    clearTimeout(hideTimer);
                });
            })();
        </script>




        <script>
            (function () {
            const canvas = document.getElementById('networkCanvas');
            const ctx = canvas.getContext('2d');
            let W, H, nodes, animFrame;
            const NODE_COUNT = 60;
            const MAX_DIST = 180;
            const SPEED = 0.4;

            function isDark() {
            return document.documentElement.getAttribute('data-theme') === 'dark';
            }

            function colors() {
            return isDark()
            ? { node: 'rgba(79,142,247,0.85)', line: 'rgba(79,142,247,', glow: 'rgba(79,142,247,0.6)' }
            : { node: 'rgba(79,142,247,0.45)', line: 'rgba(79,142,247,', glow: 'rgba(79,142,247,0.2)' };
            }

            function resize() {
            W = canvas.width  = window.innerWidth;
            H = canvas.height = window.innerHeight;
            }

            function makeNode() {
            return {
            x:  Math.random() * W,
            y:  Math.random() * H,
            vx: (Math.random() - 0.5) * SPEED,
            vy: (Math.random() - 0.5) * SPEED,
            r:  Math.random() * 2 + 1.5,
            // twinkle phase — each node independent
            phase: Math.random() * Math.PI * 2,
            speed: Math.random() * 0.02 + 0.01,
            };
            }

            function init() {
            resize();
            nodes = Array.from({ length: NODE_COUNT }, makeNode);
            }

            function draw(ts) {
            ctx.clearRect(0, 0, W, H);
            const c = colors();

            // Update positions
            for (const n of nodes) {
            n.x += n.vx;
            n.y += n.vy;
            if (n.x < 0 || n.x > W) n.vx *= -1;
            if (n.y < 0 || n.y > H) n.vy *= -1;
            n.phase += n.speed;
            }

            // Draw lines between close nodes
            for (let i = 0; i < nodes.length; i++) {
            for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j];
            const dx = a.x - b.x, dy = a.y - b.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < MAX_DIST) {
            const alpha = (1 - dist / MAX_DIST) * 0.55;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = c.line + alpha + ')';
            ctx.lineWidth = 0.6;
            ctx.stroke();
            }
            }
            }

            // Draw nodes with twinkle
            for (const n of nodes) {
            const twinkle = 0.5 + 0.5 * Math.sin(n.phase);
            const alpha = 0.3 + 0.7 * twinkle;
            const radius = n.r * (0.8 + 0.4 * twinkle);

            // Glow
            const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, radius * 4);
            grad.addColorStop(0, c.line + (alpha * 0.6) + ')');
            grad.addColorStop(1, c.line + '0)');
            ctx.beginPath();
            ctx.arc(n.x, n.y, radius * 4, 0, Math.PI * 2);
            ctx.fillStyle = grad;
            ctx.fill();

            // Core dot
            ctx.beginPath();
            ctx.arc(n.x, n.y, radius, 0, Math.PI * 2);
            ctx.fillStyle = c.line + alpha + ')';
            ctx.fill();
            }

            animFrame = requestAnimationFrame(draw);
            }

            init();
            animFrame = requestAnimationFrame(draw);

            window.addEventListener('resize', () => { resize(); });

            // Re-color when theme toggles
            const observer = new MutationObserver(() => {});
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
            })();
        </script>
    </body>


 </html>
