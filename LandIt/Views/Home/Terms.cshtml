@{
    ViewData["Title"] = "Terms of Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-page">
    <div class="content-page-inner">

            <div class="content-header">
                <div class="content-eyebrow">Legal</div>
                <h1 class="content-title">Terms of Service</h1>
                <p class="content-meta">Last updated: June 1, 2026</p>
            </div>

                <div class="content-body">

                    <div class="content-section">
                        <h2>1. Acceptance of Terms</h2>
                        <p>
                            By accessing or using LandIt, you agree to be bound by these Terms of Service.
                            If you do not agree to these terms, please do not use our platform.
                            These terms apply to all users including candidates, recruiters, and visitors.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>2. Description of Service</h2>
                        <p>LandIt provides the following services:</p>
                        <ul>
                            <li>Live 1-on-1 mock interview sessions with verified recruiters</li>
                            <li>AI-powered ATS resume analysis and resume rewriting</li>
                            <li>AI-generated interview question predictions based on job roles</li>
                            <li>Recruiter booking and scheduling tools</li>
                        </ul>
                    </div>

                    <div class="content-section">
                        <h2>3. User Accounts</h2>
                        <p>
                            You must create an account to access most features of LandIt. You are responsible
                            for maintaining the confidentiality of your account credentials and for all
                            activities that occur under your account. You agree to provide accurate and
                            complete information when registering.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>4. Recruiter Conduct</h2>
                        <p>Recruiters on LandIt agree to:</p>
                        <ul>
                            <li>Provide accurate professional information during the verification process</li>
                            <li>Conduct sessions professionally and respectfully</li>
                            <li>Honour confirmed bookings or provide adequate notice for cancellations</li>
                            <li>Not solicit candidates outside the platform for paid services</li>
                            <li>Not discriminate against candidates based on protected characteristics</li>
                        </ul>
                    </div>

                    <div class="content-section">
                        <h2>5. Candidate Conduct</h2>
                        <p>Candidates on LandIt agree to:</p>
                        <ul>
                            <li>Attend booked sessions on time or cancel with reasonable notice</li>
                            <li>Treat recruiters with respect during sessions</li>
                            <li>Not record sessions without the recruiter's explicit consent</li>
                            <li>Provide honest and accurate information in their profile and resume</li>
                        </ul>
                    </div>

                    <div class="content-section">
                        <h2>6. Payments & Refunds</h2>
                        <p>
                            Session fees are charged at the time of booking. Refunds are available if a
                            cancellation is made at least 24 hours before the scheduled session. No-shows
                            or cancellations with less than 24 hours notice are not eligible for a refund.
                            LandIt reserves the right to issue refunds at its discretion in exceptional
                            circumstances.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>7. AI-Generated Content</h2>
                        <p>
                            LandIt uses AI to generate resume rewrites and interview questions. This content
                            is provided as a tool to assist your job search and should not be considered
                            professional career advice. LandIt does not guarantee that AI-generated content
                            will result in interview success or employment. You are responsible for reviewing
                            and verifying any AI-generated content before use.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>8. Intellectual Property</h2>
                        <p>
                            The LandIt platform, including its design, code, and content, is the intellectual
                            property of LandIt. Resume content you upload remains your property. You grant
                            LandIt a limited licence to process your resume content solely for the purpose
                            of providing our services.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>9. Limitation of Liability</h2>
                        <p>
                            LandIt is provided on an "as is" basis. We make no warranties regarding the
                            accuracy of AI-generated content, the quality of recruiter sessions, or
                            employment outcomes. To the maximum extent permitted by law, LandIt shall not
                            be liable for any indirect, incidental, or consequential damages arising from
                            your use of the platform.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>10. Termination</h2>
                        <p>
                            LandIt reserves the right to suspend or terminate accounts that violate these
                            terms, engage in fraudulent activity, or behave in a manner harmful to other
                            users. You may delete your account at any time from your account settings.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>11. Changes to Terms</h2>
                        <p>
                            We may update these Terms of Service at any time. Continued use of LandIt after
                            changes are posted constitutes your acceptance of the new terms. We will notify
                            users of significant changes via email.
                        </p>
                    </div>

                    <div class="content-section">
                        <h2>12. Contact</h2>
                        <p>
                            For questions about these Terms, contact us at
                    <a href="mailto:farahhh.adel@gmail.com">admin@@landit</a> or through
                            our <a href="/Home/Contact">contact page</a>.
                        </p>
                    </div>

                </div>
            </div>
        </div>

        @section Head {
            <style>
                .content-page {
                    padding: 5rem 2.5rem;
                }

                .content-page-inner {
                    max-width: 720px;
                    margin: 0 auto;
                }

                .content-header {
                    margin-bottom: 3rem;
                    padding-bottom: 2rem;
                    border-bottom: 0.5px solid var(--border);
                }

                .content-eyebrow {
                    font-size: 0.7rem;
                    font-weight: 500;
                    letter-spacing: 0.12em;
                    color: var(--blue);
                    text-transform: uppercase;
                    margin-bottom: 0.6rem;
                }

                .content-title {
                    font-family: 'Sora', sans-serif;
                    font-size: 2rem;
                    font-weight: 700;
                    letter-spacing: -0.02em;
                    color: var(--text);
                    margin-bottom: 0.5rem;
                }

                .content-meta {
                    font-size: 0.85rem;
                    color: var(--muted);
                }

                .content-body {
                    display: flex;
                    flex-direction: column;
                    gap: 2rem;
                }

                .content-section h2 {
                    font-family: 'Sora', sans-serif;
                    font-size: 1rem;
                    font-weight: 600;
                    color: var(--text);
                    margin-bottom: 0.75rem;
                }

                .content-section p {
                    font-size: 0.9rem;
                    color: var(--muted2);
                    line-height: 1.8;
                    margin-bottom: 0.75rem;
                }

                .content-section ul {
                    padding-left: 1.25rem;
                    display: flex;
                    flex-direction: column;
                    gap: 0.4rem;
                }

                    .content-section ul li {
                        font-size: 0.9rem;
                        color: var(--muted2);
                        line-height: 1.7;
                    }

                .content-section a {
                    color: var(--blue);
                    text-decoration: underline;
                    text-underline-offset: 3px;
                }
            </style>
        }
