@model LandIt.Models.ContactMessage;
@{
    ViewData["Title"] = "Contact Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="contact-page">
    <div class="contact-inner">

            <div class="contact-info">
                <div class="content-eyebrow">Get in touch</div>
                <h1 class="contact-title">We'd love to<br />hear from you</h1>
                <p class="contact-sub">
                    Have a question, feedback, or need help with your account?
                    Send us a message and we'll get back to you as soon as possible.
                </p>

                <div class="contact-details">
                    <div class="contact-detail-item">
                        <div class="contact-detail-icon">
                            <i class="ti ti-mail" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="contact-detail-label">Email</div>
                        <a href="mailto:farahhh.adel@gmail.com" class="contact-detail-value">admin@@landit</a>
                        </div>
                    </div>
                    <div class="contact-detail-item">
                        <div class="contact-detail-icon">
                            <i class="ti ti-clock" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="contact-detail-label">Response time</div>
                            <div class="contact-detail-value">Within 24 hours</div>
                        </div>
                    </div>
                    <div class="contact-detail-item">
                        <div class="contact-detail-icon">
                            <i class="ti ti-map-pin" aria-hidden="true"></i>
                        </div>
                        <div>
                            <div class="contact-detail-label">Based in</div>
                            <div class="contact-detail-value">Amman, Jordan</div>
                        </div>
                    </div>
                </div>
            </div>

                <div class="contact-form-wrap">

                        <!--If the message was sent successfully -->
                        @if (TempData["Success"] != null)
                        {
                            <div class="contact-success">
                                <i class="ti ti-circle-check" aria-hidden="true"></i>
                                @TempData["Success"]
                            </div>
                        }

                        <form asp-action="Contact" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="form-row">
                                <div class="form-group">
                                    <label asp-for="FullName" class="form-label">Full name</label>
                                    <input asp-for="FullName" class="form-input" placeholder="John Doe" />
                                    <span asp-validation-for="FullName" class="form-error"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Email" class="form-label">Email address</label>
                                    <input asp-for="Email" type="email" class="form-input" placeholder="john@email.com" />
                                    <span asp-validation-for="Email" class="form-error"></span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Subject" class="form-label">Subject</label>
                                <input asp-for="Subject" class="form-input" placeholder="How can we help?" />
                                <span asp-validation-for="Subject" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Message" class="form-label">Message</label>
                                <textarea asp-for="Message" class="form-input form-textarea"
                                          placeholder="Tell us more about your question or feedback..."
                                          rows="6"></textarea>
                                <span asp-validation-for="Message" class="form-error"></span>
                            </div>

                            <button type="submit" class="contact-submit" id="submitBtn">
                                <span id="btnText">Send message</span>
                                <i class="ti ti-send" aria-hidden="true"></i>
                            </button>

                        </form>
                    </div>

                </div>
            </div>

            @section Head {
                <style>
                    .contact-page {
                        padding: 5rem 2.5rem;
                        min-height: calc(100vh - 65px);
                    }

                    .contact-inner {
                        max-width: 960px;
                        margin: 0 auto;
                        display: grid;
                        grid-template-columns: 1fr 1.4fr;
                        gap: 5rem;
                        align-items: start;
                    }

                    .content-eyebrow {
                        font-size: 0.7rem;
                        font-weight: 500;
                        letter-spacing: 0.12em;
                        color: var(--blue);
                        text-transform: uppercase;
                        margin-bottom: 0.75rem;
                    }

                    .contact-title {
                        font-family: 'Sora', sans-serif;
                        font-size: 2rem;
                        font-weight: 700;
                        letter-spacing: -0.02em;
                        color: var(--text);
                        line-height: 1.15;
                        margin-bottom: 1rem;
                    }

                    .contact-sub {
                        font-size: 0.9rem;
                        color: var(--muted2);
                        line-height: 1.75;
                        font-weight: 300;
                        margin-bottom: 2.5rem;
                    }

                    .contact-details {
                        display: flex;
                        flex-direction: column;
                        gap: 1.25rem;
                    }

                    .contact-detail-item {
                        display: flex;
                        align-items: flex-start;
                        gap: 12px;
                    }

                    .contact-detail-icon {
                        width: 36px;
                        height: 36px;
                        border-radius: 10px;
                        background: var(--blue-dim);
                        color: var(--blue);
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 1rem;
                        flex-shrink: 0;
                        margin-top: 2px;
                    }

                    .contact-detail-label {
                        font-size: 0.75rem;
                        color: var(--muted);
                        margin-bottom: 2px;
                    }

                    .contact-detail-value {
                        font-size: 0.875rem;
                        color: var(--text);
                        font-weight: 500;
                    }

                    a.contact-detail-value {
                        color: var(--blue);
                        text-decoration: none;
                    }

                        a.contact-detail-value:hover {
                            text-decoration: underline;
                        }

                    /* Form */
                    .contact-form-wrap {
                        background: var(--surface);
                        border: 0.5px solid var(--border);
                        border-radius: 20px;
                        padding: 2.5rem;
                    }

                    .contact-success {
                        display: flex;
                        align-items: center;
                        gap: 10px;
                        background: rgba(34, 197, 94, 0.1);
                        color: #16a34a;
                        border: 0.5px solid rgba(34, 197, 94, 0.25);
                        border-radius: 10px;
                        padding: 0.85rem 1rem;
                        font-size: 0.875rem;
                        font-weight: 500;
                        margin-bottom: 1.5rem;
                    }

                    [data-theme="dark"] .contact-success {
                        color: #4ade80;
                    }

                    .form-row {
                        display: grid;
                        grid-template-columns: 1fr 1fr;
                        gap: 1rem;
                        margin-bottom: 1rem;
                    }

                    .form-group {
                        display: flex;
                        flex-direction: column;
                        gap: 6px;
                        margin-bottom: 1rem;
                    }

                    .form-label {
                        font-size: 0.82rem;
                        font-weight: 500;
                        color: var(--muted2);
                    }

                    .form-input {
                        padding: 0.65rem 1rem;
                        border-radius: 10px;
                        border: 0.5px solid var(--border);
                        background: var(--surface2);
                        color: var(--text);
                        font-family: 'Inter', sans-serif;
                        font-size: 0.875rem;
                        outline: none;
                        transition: border-color 0.2s, background 0.25s;
                        width: 100%;
                    }

                        .form-input:focus {
                            border-color: rgba(79, 142, 247, 0.5);
                        }

                        .form-input::placeholder {
                            color: var(--muted);
                        }

                    .form-textarea {
                        resize: vertical;
                        min-height: 120px;
                    }

                    .form-error {
                        font-size: 0.78rem;
                        color: #ef4444;
                    }

                    .contact-submit {
                        width: 100%;
                        padding: 0.75rem;
                        background: var(--blue);
                        color: #fff;
                        border: none;
                        border-radius: 10px;
                        font-family: 'Inter', sans-serif;
                        font-size: 0.9rem;
                        font-weight: 500;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        gap: 8px;
                        transition: opacity 0.2s;
                        margin-top: 0.5rem;
                    }

                        .contact-submit:hover {
                            opacity: 0.9;
                        }

                        .contact-submit:disabled {
                            opacity: 0.6;
                            cursor: not-allowed;
                        }

                    @@media (max-width: 768px) {
                        .contact-inner {
                            grid-template-columns: 1fr;
                            gap: 2.5rem;
                        }

                        .form-row {
                            grid-template-columns: 1fr;
                        }

                        .contact-page {
                            padding: 3rem 1.25rem;
                        }
                    }
                </style>
            }

            @section Scripts {
                @{
                    await Html.RenderPartialAsync("_ValidationScriptsPartial");
                }
                <script>
                    document.querySelector('form').addEventListener('submit', function () {
                        var btn = document.getElementById('submitBtn');
                        btn.disabled = true;
                        document.getElementById('btnText').textContent = 'Sending…';
                    });
                </script>
            }
