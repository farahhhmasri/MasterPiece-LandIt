@model IEnumerable<LandIt.Models.RecruiterReview>
@{
    ViewData["Title"] = "Reviews";
    ViewData["UseBootstrap"] = true;
    ViewData["UseIdentityStyles"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var reviewList = Model.ToList();
    var avgRating = reviewList.Any() ? reviewList.Average(r => r.Rating) : 0;
    var count5 = reviewList.Count(r => r.Rating == 5);
    var count4 = reviewList.Count(r => r.Rating == 4);
    var count3 = reviewList.Count(r => r.Rating == 3);
    var count2 = reviewList.Count(r => r.Rating == 2);
    var count1 = reviewList.Count(r => r.Rating == 1);
    var total = reviewList.Count;
}

<div class="app-container">

    <!--Header-->
        <div style="margin-bottom:2rem;">
            <a href="/Recruiter/Dashboard"
               style="font-size:0.82rem;color:var(--muted2);display:inline-flex;align-items:center;gap:4px;text-decoration:none;margin-bottom:1rem;">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Back to Dashboard
            </a>
            <div class="sec-eyebrow">Feedback</div>
            <h1 class="sec-title" style="margin-bottom:0.25rem;">Your Reviews</h1>
            <p class="step-desc">What candidates are saying about your mock interview sessions.</p>
        </div>

        @if (!reviewList.Any())
        {
            <div class="app-card" style="text-align:center;padding:3rem 2rem;">
                <i class="ti ti-star-off" aria-hidden="true"
                   style="font-size:2.5rem;color:var(--muted);display:block;margin-bottom:1rem;"></i>
                <p style="font-size:0.95rem;font-weight:500;color:var(--text);margin-bottom:0.4rem;">No reviews yet</p>
                <p style="font-size:0.85rem;color:var(--muted2);margin:0;">
                    Reviews will appear here after candidates complete sessions with you.
                </p>
            </div>
        }
        else
        {
            <div class="row g-4">

                <!-- Left column — rating summary -->
                    <div class="col-md-4">
                        <div class="app-card" style="text-align:center;margin-bottom:1rem;">

                            <!-- Big average number -->
                                <p style="font-family:'Sora',sans-serif;font-size:3.5rem;font-weight:700;color:var(--text);margin:0;line-height:1;">
                                    @avgRating.ToString("0.0")
                                </p>
                                <p style="font-size:0.82rem;color:var(--muted);margin:4px 0 0.85rem;">out of 5</p>

                                <!-- Star display -->
                                    <div style="display:flex;justify-content:center;gap:3px;margin-bottom:0.75rem;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span style="font-size:1.25rem;color:@(i <= Math.Round(avgRating) ? "#f59e0b" : "var(--muted)");">★</span>
                                        }
                                    </div>

                                    <p style="font-size:0.78rem;color:var(--muted);margin:0;">@total review@(total != 1 ? "s" : "")</p>

                                    <hr style="border-color:var(--border);margin:1.25rem 0;" />

                                    <!-- Rating breakdown bars -->
                                        <div style="display:flex;flex-direction:column;gap:6px;text-align:left;">
                                            @foreach (var (stars, cnt) in new[] { (5, count5), (4, count4), (3, count3), (2, count2), (1, count1) })
                                            {
                                                int pct = total > 0 ? (int)Math.Round((double)cnt / total * 100) : 0;
                                                <div style="display:flex;align-items:center;gap:8px;">
                                                    <span style="font-size:0.75rem;color:var(--muted);min-width:14px;">@stars</span>
                                                    <span style="font-size:0.8rem;color:#f59e0b;">★</span>
                                                    <div style="flex:1;height:6px;background:var(--surface2);border-radius:100px;overflow:hidden;">
                                                        <div style="height:100%;width:@(pct)%;background:#f59e0b;border-radius:100px;"></div>
                                                    </div>
                                                    <span style="font-size:0.72rem;color:var(--muted);min-width:24px;text-align:right;">@cnt</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Right column — review list -->
                                    <div class="col-md-8">
                                        <div style="display:flex;flex-direction:column;gap:1rem;">
                                            @foreach (var review in reviewList.OrderByDescending(r => r.CreatedAt))
                                            {
                                                <div class="app-card">

                                                    <!-- Top row: user + date -->
                                                        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
                                                            <div style="display:flex;align-items:center;gap:10px;">
                                                                <div style="width:36px;height:36px;border-radius:50%;background:var(--blue-dim);color:var(--blue);font-size:0.85rem;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                                                    @(review.User?.FullName?.Substring(0, 1).ToUpper())
                                                                </div>
                                                                <div>
                                                                    <p style="font-size:0.875rem;font-weight:600;color:var(--text);margin:0;">@review.User?.FullName</p>
                                                                    <p style="font-size:0.75rem;color:var(--muted);margin:0;">@review.CreatedAt.ToString("MMM dd, yyyy")</p>
                                                                </div>
                                                            </div>

                                                            <!-- Stars -->
                                                                <div style="display:flex;gap:2px;flex-shrink:0;">
                                                                    @for (int i = 1; i <= 5; i++)
                                                                    {
                                                                        <span style="font-size:0.9rem;color:@(i <= review.Rating ? "#f59e0b" : "var(--muted)");">★</span>
                                                                    }
                                                                </div>
                                                            </div>

                                                            <!-- Comment -->
                                                                @if (!string.IsNullOrWhiteSpace(review.Comment))
                                                                {
                                                                    <p style="font-size:0.875rem;color:var(--muted2);line-height:1.7;margin:0;font-style:italic;">
                                                                        "@review.Comment"
                                                                    </p>
                                                                }
                                                                else
                                                                {
                                                                    <p style="font-size:0.82rem;color:var(--muted);margin:0;font-style:italic;">No written comment.</p>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
