@model List<LandIt.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
    ViewData["UseBootstrap"] = true;
    ViewData["UseIdentityStyles"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var pending   = Model?.Where(b => b.Status == LandIt.Models.BookingStatus.Pending).Count()   ?? 0;
    var confirmed = Model?.Where(b => b.Status == LandIt.Models.BookingStatus.Confirmed).Count() ?? 0;
    var cancelled = Model?.Where(b => b.Status == LandIt.Models.BookingStatus.Cancelled).Count() ?? 0;
}

<div class="app-container">

    <!--Header-->
    <div style="margin-bottom:2rem;">
        <a href="/Recruiter/Dashboard"
           style="font-size:0.82rem;color:var(--muted2);display:inline-flex;align-items:center;gap:4px;text-decoration:none;margin-bottom:1rem;">
            <i class="ti ti-arrow-left" aria-hidden="true"></i> Back to Dashboard
        </a>
        <div class="sec-eyebrow">Sessions</div>
        <h1 class="sec-title" style="margin-bottom:0.25rem;">Your Bookings</h1>
        <p class="step-desc">Manage interview session requests from candidates.</p>
    </div>

    <!-- Flash messages -->
    @if (TempData["Success"] != null)
    {
        <div style="background:rgba(34,197,94,0.1);border:0.5px solid rgba(34,197,94,0.25);border-radius:10px;padding:0.85rem 1rem;margin-bottom:1.5rem;font-size:0.875rem;color:#16a34a;display:flex;align-items:center;gap:8px;">
            <i class="ti ti-circle-check" aria-hidden="true"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background:rgba(239,68,68,0.1);border:0.5px solid rgba(239,68,68,0.25);border-radius:10px;padding:0.85rem 1rem;margin-bottom:1.5rem;font-size:0.875rem;color:#dc2626;display:flex;align-items:center;gap:8px;">
            <i class="ti ti-alert-circle" aria-hidden="true"></i> @TempData["Error"]
        </div>
    }

    <!-- Stats row -->
    @if (Model != null && Model.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="app-card text-center">
                    <i class="ti ti-clock" aria-hidden="true" style="font-size:1.5rem;color:#d97706;"></i>
                    <p style="font-size:1.5rem;font-weight:600;color:var(--text);margin:4px 0 2px;">@pending</p>
                    <p style="font-size:0.75rem;color:var(--muted);margin:0;">Pending</p>
                </div>
            </div>
            <div class="col-4">
                <div class="app-card text-center">
                    <i class="ti ti-circle-check" aria-hidden="true" style="font-size:1.5rem;color:#16a34a;"></i>
                    <p style="font-size:1.5rem;font-weight:600;color:var(--text);margin:4px 0 2px;">@confirmed</p>
                    <p style="font-size:0.75rem;color:var(--muted);margin:0;">Confirmed</p>
                </div>
            </div>
            <div class="col-4">
                <div class="app-card text-center">
                    <i class="ti ti-circle-x" aria-hidden="true" style="font-size:1.5rem;color:#dc2626;"></i>
                    <p style="font-size:1.5rem;font-weight:600;color:var(--text);margin:4px 0 2px;">@cancelled</p>
                    <p style="font-size:0.75rem;color:var(--muted);margin:0;">Cancelled</p>
                </div>
            </div>
        </div>
    }

    <!-- Bookings list -->
    @if (Model == null || !Model.Any())
    {
        <div class="app-card" style="text-align:center;padding:3rem 2rem;">
            <i class="ti ti-calendar-off" aria-hidden="true"
               style="font-size:2.5rem;color:var(--muted);display:block;margin-bottom:1rem;"></i>
            <p style="font-size:0.95rem;font-weight:500;color:var(--text);margin-bottom:0.4rem;">No bookings yet</p>
            <p style="font-size:0.85rem;color:var(--muted2);margin-bottom:1.5rem;">
                Set your availability so candidates can start booking sessions with you.
            </p>
            <a href="/Recruiter/Availability"
               class="btn-primary"
               style="display:inline-flex;align-items:center;gap:6px;padding:0.6rem 1.5rem;text-decoration:none;">
                <i class="ti ti-calendar-plus" aria-hidden="true"></i> Set Availability
            </a>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:1rem;">
            @foreach (var booking in Model)
            {
                <!-- Per-booking status styles -->
                
                    string statusBg    = booking.Status == LandIt.Models.BookingStatus.Confirmed ? "rgba(34,197,94,0.1)"
                                       : booking.Status == LandIt.Models.BookingStatus.Pending   ? "rgba(251,191,36,0.1)"
                                       : "rgba(239,68,68,0.1)";
                    string statusColor = booking.Status == LandIt.Models.BookingStatus.Confirmed ? "#16a34a"
                                       : booking.Status == LandIt.Models.BookingStatus.Pending   ? "#d97706"
                                       : "#dc2626";
                    string statusIcon  = booking.Status == LandIt.Models.BookingStatus.Confirmed ? "ti-circle-check"
                                       : booking.Status == LandIt.Models.BookingStatus.Pending   ? "ti-clock"
                                       : "ti-circle-x";
                

                <div class="app-card">

                    <!-- Top row: candidate info + status -->
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:1rem;">
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div style="width:40px;height:40px;border-radius:50%;background:var(--blue-dim);color:var(--blue);font-size:1rem;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                @(booking.User?.FullName?.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <p style="font-size:0.95rem;font-weight:600;color:var(--text);margin:0;">
                                    @booking.User?.FullName
                                </p>
                                <p style="font-size:0.82rem;color:var(--muted2);margin:0;">
                                    @booking.JobTitle
                                    @if (!string.IsNullOrWhiteSpace(booking.CompanyTarget))
                                    {
                                        <span style="color:var(--muted);"> · @booking.CompanyTarget</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <span style="font-size:0.72rem;font-weight:500;padding:4px 10px;border-radius:100px;background:@statusBg;color:@statusColor;border:0.5px solid @statusColor;display:inline-flex;align-items:center;gap:5px;">
                            <i class="ti @statusIcon" aria-hidden="true" style="font-size:0.75rem;"></i>
                            @booking.Status
                        </span>
                    </div>

                    <!-- Details row -->
                    <div style="display:flex;flex-wrap:wrap;gap:1rem;padding:0.75rem 1rem;background:var(--surface2);border-radius:10px;margin-bottom:1rem;">
                        <div style="display:flex;align-items:center;gap:6px;">
                            <i class="ti ti-calendar-event" aria-hidden="true" style="color:var(--blue);font-size:0.9rem;"></i>
                            <span style="font-size:0.82rem;color:var(--muted2);">
                                @booking.TimeSlot?.StartTime.ToString("MMM dd, yyyy")
                            </span>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <i class="ti ti-clock" aria-hidden="true" style="color:var(--blue);font-size:0.9rem;"></i>
                            <span style="font-size:0.82rem;color:var(--muted2);">
                                @booking.TimeSlot?.StartTime.ToString("h:mm tt") — @booking.TimeSlot?.EndTime.ToString("h:mm tt")
                            </span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(booking.MeetingUrl))
                        {
                            <div style="display:flex;align-items:center;gap:6px;">
                                <i class="ti ti-video" aria-hidden="true" style="color:var(--blue);font-size:0.9rem;"></i>
                                <a href="@booking.MeetingUrl" target="_blank"
                                   style="font-size:0.82rem;color:var(--blue);text-decoration:none;">
                                    Join meeting
                                </a>
                            </div>
                        }
                    </div>

                    <!-- Candidate notes -->
                    @if (!string.IsNullOrWhiteSpace(booking.Notes))
                    {
                        <div style="display:flex;align-items:flex-start;gap:8px;padding:0.65rem 0.85rem;background:var(--surface2);border-radius:8px;margin-bottom:1rem;">
                            <i class="ti ti-notes" aria-hidden="true" style="color:var(--muted2);font-size:0.9rem;flex-shrink:0;margin-top:2px;"></i>
                            <p style="font-size:0.82rem;color:var(--muted2);margin:0;line-height:1.6;">
                                <strong style="color:var(--text);">Candidate notes:</strong> @booking.Notes
                            </p>
                        </div>
                    }

                    <!-- Action buttons -->
                    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">

                        <a href="/Recruiter/SessionDetails/@booking.Id"
                           class="btn-ghost"
                           style="display:inline-flex;align-items:center;gap:5px;padding:0.45rem 1rem;text-decoration:none;font-size:0.82rem;">
                            <i class="ti ti-eye" aria-hidden="true"></i> View details
                        </a>

                        @if (booking.Status == LandIt.Models.BookingStatus.Pending)
                        {
                            <form asp-action="ApproveBooking" method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@booking.Id" />
                                <button type="submit"
                                        class="btn-primary"
                                        style="display:inline-flex;align-items:center;gap:5px;padding:0.45rem 1rem;font-size:0.82rem;">
                                    <i class="ti ti-circle-check" aria-hidden="true"></i> Approve
                                </button>
                            </form>

                            <form asp-action="RejectBooking" method="post"
                                  onsubmit="return confirm('Are you sure you want to reject this booking?');"
                                  style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@booking.Id" />
                                <button type="submit"
                                        style="background:none;border:0.5px solid rgba(239,68,68,0.35);color:#dc2626;font-size:0.82rem;padding:0.45rem 1rem;border-radius:8px;cursor:pointer;font-family:'Inter',sans-serif;display:inline-flex;align-items:center;gap:5px;">
                                    <i class="ti ti-circle-x" aria-hidden="true"></i> Reject
                                </button>
                            </form>
                        }

                        @if (booking.Status == LandIt.Models.BookingStatus.Confirmed)
                        {
                            <form asp-action="CompleteSession" method="post"
                                  onsubmit="return confirm('Mark this session as completed?');"
                                  style="margin:0;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@booking.Id" />
                                <button type="submit"
                                        style="background:rgba(34,197,94,0.1);border:0.5px solid rgba(34,197,94,0.35);color:#16a34a;font-size:0.82rem;padding:0.45rem 1rem;border-radius:8px;cursor:pointer;font-family:'Inter',sans-serif;display:inline-flex;align-items:center;gap:5px;">
                                    <i class="ti ti-check" aria-hidden="true"></i> Mark complete
                                </button>
                            </form>
                        }

                    </div>
                </div>
            }
        </div>
    }
</div>
