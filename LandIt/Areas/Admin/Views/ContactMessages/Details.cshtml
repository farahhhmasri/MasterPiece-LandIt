@model LandIt.Models.ContactMessage
@{
    ViewData["Title"] = "Message";
    string Initials(string? n) => string.IsNullOrWhiteSpace(n) ? "?" : string.Concat(n.Split(' ').Where(p => p.Length > 0).Take(2).Select(p => p[0])).ToUpper();
}

<div class="page-head">
    <div>
        <a asp-action="Index" class="btn sm ghost" style="margin-bottom:8px;"><i class="ti ti-arrow-left"></i> All messages</a>
        <h1>@Model.Subject</h1>
        <div class="sub">@Model.CreatedAt.ToString("dddd, MMM d yyyy · HH:mm")</div>
    </div>
    <div class="actions">
        @if (Model.RepliedAt != null) { <span class="badge success">Replied</span> }
        else { <span class="badge info">New</span> }
    </div>
</div>

<div class="card-x">
    <div style="display:flex; align-items:center; gap:12px; padding-bottom:16px; border-bottom:1px solid var(--border);">
        <div class="avatar lg">@Initials(Model.FullName)</div>
        <div style="flex:1;">
            <div style="font-weight:600;">@Model.FullName</div>
            <div style="color:var(--muted); font-size:13px;">@Model.Email</div>
        </div>
        <a href="mailto:@Model.Email?subject=Re: @Model.Subject" class="btn sm ghost"><i class="ti ti-external-link"></i> Email client</a>
    </div>
    <p style="white-space:pre-wrap; color:var(--muted2); line-height:1.7; font-size:14.5px; margin:18px 0 0;">@Model.Message</p>
</div>

<div class="card-x">
    <h3>Reply</h3>
    @if (Model.RepliedAt != null)
    {
        <div style="font-size:12.5px; color:var(--muted); margin-bottom:8px;">Last replied @Model.RepliedAt?.ToString("yyyy-MM-dd HH:mm")</div>
    }
    <form asp-action="Reply" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <textarea name="reply" class="input-x" rows="6" placeholder="Write your reply…" required>@Model.AdminReply</textarea>
        <div style="display:flex; justify-content:flex-end; margin-top:12px;">
            <button class="btn primary" type="submit"><i class="ti ti-send"></i> Save reply</button>
        </div>
    </form>
</div>
